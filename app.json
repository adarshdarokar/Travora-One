{
  "expo": {
    "name": "Travora-one",
    "slug": "Travora-one",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "travoraone",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "extra": {
      "GEO_API_KEY": "e88f2f7d70774c7da579a6b795af5d5c"
    },

    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}